page {
  background: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "PingFang SC", "Microsoft YaHei", sans-serif;
}
.container { padding: 20rpx; }
.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}
.card-title { font-size: 32rpx; font-weight: 600; margin-bottom: 20rpx; }
.stat-grid { display: flex; flex-wrap: wrap; gap: 20rpx; }
.stat-item {
  flex: 1;
  min-width: 200rpx;
  background: linear-gradient(135deg, #4facfe, #00f2fe);
  border-radius: 16rpx;
  padding: 30rpx;
  text-align: center;
  color: #fff;
}
.stat-item .value { font-size: 48rpx; font-weight: 700; }
.stat-item .label { font-size: 24rpx; opacity: 0.8; margin-top: 10rpx; }
.list-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}
.list-item:last-child { border-bottom: none; }
.badge {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
}
.badge-active { background: #f6ffed; color: #52c41a; }
.badge-inactive { background: #fff1f0; color: #ff4d4f; }
.btn {
  display: inline-block;
  padding: 16rpx 32rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  text-align: center;
}
.btn-primary {
  background: linear-gradient(135deg, #4facfe, #00f2fe);
  color: #fff;
}
.search-bar {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 12rpx;
  padding: 16rpx 24rpx;
  margin-bottom: 20rpx;
}
.search-bar input { flex: 1; margin-left: 16rpx; font-size: 28rpx; }
