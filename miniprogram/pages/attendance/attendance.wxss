.form-row { display: flex; gap: 20rpx; }
.form-group { flex: 1; margin-bottom: 20rpx; }
.label { font-size: 24rpx; color: #666; margin-bottom: 8rpx; display: block; }
.picker { padding: 16rpx 20rpx; background: #f5f5f5; border-radius: 12rpx; font-size: 26rpx; }
.att-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16rpx; padding-bottom: 12rpx; border-bottom: 1rpx solid #f0f0f0; }
.select-count { color: #4facfe; font-size: 24rpx; }
.att-item { display: flex; align-items: center; padding: 20rpx 0; border-bottom: 1rpx solid #f0f0f0; }
.att-check { width: 44rpx; height: 44rpx; border-radius: 50%; border: 2rpx solid #ddd; display: flex; align-items: center; justify-content: center; margin-right: 20rpx; font-size: 24rpx; color: #fff; }
.att-check.checked { background: #4facfe; border-color: #4facfe; }
.att-info { flex: 1; }
.att-name { font-size: 28rpx; font-weight: 500; display: block; }
.att-detail { font-size: 22rpx; color: #999; margin-top: 4rpx; display: block; }
