<view class="container">
  <view class="stat-grid">
    <view class="stat-card"><text class="stat-value">{{stats.total_students}}</text><text class="stat-label">总学员数</text></view>
    <view class="stat-card"><text class="stat-value">{{stats.active_students}}</text><text class="stat-label">在读学员</text></view>
    <view class="stat-card"><text class="stat-value">{{stats.potential_students}}</text><text class="stat-label">潜在学员</text></view>
    <view class="stat-card"><text class="stat-value">{{stats.total_hours}}</text><text class="stat-label">总课时</text></view>
    <view class="stat-card"><text class="stat-value">{{stats.remaining_hours}}</text><text class="stat-label">剩余课时</text></view>
    <view class="stat-card"><text class="stat-value">{{stats.consumption_rate}}%</text><text class="stat-label">消耗率</text></view>
  </view>
</view>
